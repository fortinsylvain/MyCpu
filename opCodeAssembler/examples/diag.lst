95E0 2A 1F FB            LDA CARRY   ; Read Carry bit <0>
95E3 21 00               TEQA #0x00  ; Expecting C=0
95E5 2B FF B0            JNE FAIL
95E8 30 8A               LDA #0x8A
95EA 2F BD               ADDA #0xBD
95EC 21 47               TEQA #0x47   
95EE 2B FF B0            JNE FAIL
95F1 2A 1F FB            LDA CARRY   ; Read Carry bit <0>
95F4 21 01               TEQA #0x01  ; Expecting C=1
95F6 2B FF B0            JNE FAIL
95F9 30 01               LDA #0x01
95FB 2F 02               ADDA #0x02
95FD 21 03               TEQA #0x03
95FF 2B FF B0            JNE FAIL
9602 2A 1F FB            LDA CARRY   ; Read Carry bit <0>
9605 21 00               TEQA #0x00  ; Expecting C=0
9607 2B FF B0            JNE FAIL
960A 30 FF               LDA #0xFF
960C 2F FF               ADDA #0xFF
