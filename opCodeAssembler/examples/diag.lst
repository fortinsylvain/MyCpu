                         ; OP.23 JRUGE Jump Relative Unsigned Greater or Equal (Condition C = 1)
                         ; --------------------------------------------------------------------
917C 30 23      TSTOP23  LDA #0x23
917E 19                  NOTA
917F 31 78 00            STA LEDPORT    ; Output to LED port
9182 30 C4               LDA #0xC4      ; -- Test when equal (C=1)
9184 2D C4               CMPA #0xC4
