                                  ; MUL 8-bit
                                  ; w1 (b3,b2) <= b1 * b0
A16F 26         ?mul8_w1_b1_b0    CLRA        ; Only clear ?b3
A170 31 00 0C                     STA ?b3
A173 04 00 08                     LDX #0x0008 ; Loop counter (8 bits)
A176 15 00 0F   ?mul8_w1_b1_loop  SRL ?b0     ; Shift right ?b0 (check LSB)
A179 0F 09                        JRNC ?mul8_skip_add  ; Conditional relative jump if not Carry ( If LSB was 0, skip addition)
A17B 2A 00 0C                     LDA ?b3
A17E 29 00 0E                     ADDA ?b1    ; Add multiplicand
A181 31 00 0C                     STA ?b3     ; Store back
A184 14 00 0C   ?mul8_skip_add    RRC ?b3     ; Shift right ?b3 ?b2   C -> 7 6 5 4 3 2 1 0 -> C
A187 14 00 0D                     RRC ?b2     ;                       C -> 7 6 5 4 3 2 1 0 -> C
A18A 13                           DECXL       ; Decrement loop counter
A18B 2B A1 76                     JNE ?mul8_w1_b1_loop
A18E 07                           RTS

                                  ; MUL 16-bit
                                  ; l1 <= w1 * w0      (b7,b6,b5,b4) = (b3,b2) * (b1,b0)
A18F 26         ?mul16_l1_w1_w0   CLRA        ; Only clear ?b7 and ?b6
A190 31 00 08                     STA ?b7
A193 31 00 09                     STA ?b6
A196 04 00 10                     LDX #0x0010 ; Loop counter (16 bits)
A199 15 00 0E   ?mul16_l1_w1_loop SRL ?b1     ; Shift right ?w0 (check LSB)  '0' -> 7 6 5 4 3 2 1 0 -> C
A19C 14 00 0F                     RRC ?b0     ; C  -> 7 6 5 4 3 2 1 0 -> C
A19F 0F 12                        JRNC ?mul16_skip_add  ; Conditional relative jump if not Carry ( If LSB was 0, skip addition)
A1A1 2A 00 09                     LDA ?b6
A1A4 29 00 0D                     ADDA ?b2    ; Add multiplicand
A1A7 31 00 09                     STA ?b6     ; Store back
A1AA 2A 00 08                     LDA ?b7
A1AD 28 00 0C                     ADCA ?b3
A1B0 31 00 08                     STA ?b7
A1B3 14 00 08   ?mul16_skip_add   RRC ?b7     ; Shift right ?b7 ?b6 ?b5 ?b4   C -> 7 6 5 4 3 2 1 0 -> C 
A1B6 14 00 09                     RRC ?b6     ;                               C -> 7 6 5 4 3 2 1 0 -> C
A1B9 14 00 0A                     RRC ?b5
A1BC 14 00 0B                     RRC ?b4
A1BF 13                           DECXL       ; Decrement loop counter
A1C0 2B A1 99                     JNE ?mul16_l1_w1_loop
A1C3 07                           RTS


                                  ; MUL 32-bit by 8-bit unsigned
                                  ; l1 = l0 * A   (A = 8-bit multiplier, A <= 12)
                                  ; l0 = (b3,b2,b1,b0)
                                  ; result -> l1 = (b7..b4)
                ;?mul32_l1_l0_u8   ; ---- multiply LOW word ----
                ;                  STA TMPN          ; save multiplier

                ;                  LDA ?b0
                ;                  STA ?b0           ; w0 low
                ;                  LDA ?b1
                ;                  STA ?b1

                ;                  LDA TMPN
                ;                  STA ?b2           ; w1 = n
                ;                  LDA #0
                ;                  STA ?b3

                ;                  JSR ?mul16_l1_w1_w0   ; l1 = LO16 * n

                                  ; save low result
                ;                  LDA ?b4
                ;                  STA RES0
                ;                  LDA ?b5
                ;                  STA RES1

                                  ; ---- multiply HIGH word ----
                ;                  LDA ?b2           ; restore high word of l0
                ;                  STA ?b0
                ;                  LDA ?b3
                ;                  STA ?b1

                ;                  LDA TMPN
                ;                  STA ?b2
                ;                  LDA #0
                ;                  STA ?b3

                ;                  JSR ?mul16_l1_w1_w0   ; l1 = HI16 * n

                                  ; ---- accumulate ----
                ;                  LDA ?b4
                ;                  ADDA RES1
                ;                  STA ?b5
                ;                  LDA ?b5
                ;                  ADCA #0
                ;                  STA ?b6
                ;                  LDA ?b6
                ;                  ADCA #0
                ;                  STA ?b7

                ;                  LDA RES0
                ;                  STA ?b4

                ;                  RTS

                ;--------------------------------------------
                ; DIV8 - Unsigned 8-bit division using stack
                ; Input:
                ;   XL = dividend (0–255)
                ;   A  = divisor  (1–255)
                ; Output:
                ;   A  = quotient
                ;   XL = remainder
                ; Uses stack for divisor storage
                ;--------------------------------------------
                ;DIV8     PSHA           ; save divisor on stack
                ;         CLRA           ; quotient = 0
                ;DIV8_L1  PEEK           ; read top of stack into temporary A (do not pop yet)
                ;         CMPXL A        ; compare remainder with divisor
                ;         JRULT DivDone  ; if remainder < divisor → done
                ;         SUBXL A        ; XL = XL - divisor
                ;         INCA           ; quotient++
                ;         JRA DIV8_L1
                ;DivDone  POPA           ; remove divisor from stack
                ;         RTS

                ;--------------------------------------------
                ; LCD Main Initialization Routine
                ;--------------------------------------------
A1C4 30 FF      LCD_Init    LDA #0xFF         ; Wait >40ms (simple busy loop)
A1C6 20         Delay40ms   DECA
A1C7 2B A1 C6               JNE Delay40ms

                            ; Function set: 8-bit, 2 line, 5x8 font
                            ; <5> 1
                            ; <4> DL = 1  0: 4-bit inteface, 1:8-bit interface
                            ; <3> N = 1   0: 1 Line, 1: 2 Lines
                            ; <2> F = 0   0: FONT_5x8, 1: FONT_5x10
                            ; <1> -  -
                            ; <0> -  -
A1CA 30 38                  LDA #0x38
A1CC 31 7C 00               STA LCD_CMD

                            ; Wait >4.1ms
A1CF 30 F0                  LDA #0xF0
A1D1 20         Delay4ms    DECA
A1D2 2B A1 D1               JNE Delay4ms

                            ; Display ON/OFF Control
                            ; Display ON, cursor OFF, blink OFF
                            ; <3> 1
                            ; <2> D = 1  Display ON/OFF Control 0:OFF, 1:ON
                            ; <1> C = 0  Cursor displayed 0:OFF, 1:ON
                            ; <0> B = 0  Blinking of cursor position character 0:OFF, 1:ON
A1D5 30 0C                  LDA #0x0C
A1D7 31 7C 00               STA LCD_CMD

                            ; Entry mode set
                            ; Entry mode: left-to-right, no shift
                            ; <2> 1
                            ; <1> I/D = 1  Increment/Decrement of DDRAM address 1: Increment, 0: Decrement
                            ; <0> S = 0    
A1DA 30 06                  LDA #0x06
A1DC 31 7C 00               STA LCD_CMD
A1DF 07                     RTS

                ;--------------------------------------------
                ; Clear display
                ;--------------------------------------------
A1E0 30 01      LCD_Clear   LDA #0x01      ; Clear display command; <0> = 1
A1E2 31 7C 00               STA LCD_CMD
A1E5 30 FF                  LDA #0xFF      ; Wait >1.5ms (for clear command)
A1E7 20         DelayClear  DECA
A1E8 2B A1 E7               JNE DelayClear
A1EB 07                     RTS

                ;--------------------------------------------
                ; Set LCD Cursor Position
                ; Input:
                ;   XH = line (0 or 1)
                ;   XL = column (0..15)
                ;--------------------------------------------
A1EC 2A 1F F3   LCD_SetCursorPos  LDA XH      
A1EF 21 00                        TEQA #0x00
A1F1 2C A1 F8                     JEQ LCD_Row0
A1F4 30 40                        LDA #0x40         ; Row 1, DDRAM base address line 1
A1F6 0C 01                        JRA LCD_AddCol
A1F8 26         LCD_Row0          CLRA              ; DDRAM base address line 0
A1F9 29 1F F4   LCD_AddCol        ADDA XL           ; A = base + column
A1FC 17 80                        ORA #0x80         ; Set DDRAM address command
A1FE 31 7C 00                     STA LCD_CMD
A201 07                           RTS     

                ;--------------------------------------------
                ; Write a single character
                ; Input: A = ASCII code
                ;--------------------------------------------
A202 31 7C 01   LCD_PrintChar  STA LCD_DATA
A205 07                        RTS

                ;--------------------------------------------
                ; Print null-terminated string
                ; Input:
                ;   X = address of string
                ;--------------------------------------------
A206 0A         LCD_PrintString   LDA (X)        ; A = *X
A207 21 00                        TEQA #0x00     ; end of string?
A209 2C A2 12                     JEQ LCD_PrDone
A20C 06 A2 02                     JSR LCD_PrintChar
A20F 05                           INCX           ; X++
A210 0C F4                        JRA LCD_PrintString
A212 07         LCD_PrDone        RTS

                ;--------------------------------------------
                ; Print HEX digit (0-15) as ASCII ('0'-'9', 'A'-'F')
                ; Input:
                ;   A = nibble
                ;--------------------------------------------
A213 33 0F      LCD_PrintHexDigit ANDA #0x0F     ; Mask to 4 bits
A215 2D 0A                        CMPA #0x0A
A217 23 04                        JRUGE LCD_PrintHL
A219 2F 30                        ADDA #0x30     ; Convert 0..9 to '0'..'9'
A21B 0C E5                        JRA LCD_PrintChar
A21D 2F 37      LCD_PrintHL       ADDA #0x37     ; Convert 10..15 to 'A'..'F'
A21F 0C E1                        JRA LCD_PrintChar
                ;--------------------------------------------
                ; Print a 8-bit value as two hex digits
                ; Input:
                ;   A = byte to print
                ;--------------------------------------------
A221 24         LCD_PrintHex8     PSHA           ; save original byte on stack
A222 0D                           SRLA           ; High nibble
A223 0D                           SRLA
A224 0D                           SRLA
A225 0D                           SRLA
A226 06 A2 13                     JSR LCD_PrintHexDigit
A229 25                           POPA           ; restore byte
A22A 33 0F                        ANDA #0x0F     ; low nibble
A22C 06 A2 13                     JSR LCD_PrintHexDigit
A22F 07                           RTS
                ;------------------------------------------------------------
                ; Print a 16-bit value as four hex digits
                ; Input:
                ;   X = 16-bit value
                ;------------------------------------------------------------
A230 2A 1F F3   LCD_PrintHex16    LDA XH
A233 06 A2 21                     JSR LCD_PrintHex8
A236 2A 1F F4                     LDA XL
A239 06 A2 21                     JSR LCD_PrintHex8
A23C 07                           RTS
                ;------------------------------------------------------------
                ; Print a byte as decimal (0..255) at current cursor position
                ; Input:
                ;   A = byte to print
                ;------------------------------------------------------------
A23D 1E         LCD_PrintDecByte  CLRX                    ; Clear X, X = hundred counter
A23E 2D 64      LCD_PDB_L1        CMPA #0x64              ; Compare with 100
A240 23 02                        JRUGE LCD_PDB_J1
A242 0C 05                        JRA LCD_PDB_J2
A244 2F 9C      LCD_PDB_J1        ADDA #0x9C              ; subtract 100 (A = A - 100)
A246 05                           INCX
A247 0C F5                        JRA LCD_PDB_L1
A249 24         LCD_PDB_J2        PSHA                    ; Save remaining value (0..99) on stack
A24A 2A 1F F4                     LDA XL                  ; Load X (hundred counter) into A
A24D 06 A2 13                     JSR LCD_PrintHexDigit   ; Print hundred digit as hex (0..9)
A250 25                           POPA                    ; restore remaining value (0..99) into A
A251 1E                           CLRX                    ; Clear X, X = ten counter
A252 2D 0A      LCD_PDB_L3        CMPA #0x0A              ; Compare with 10
A254 23 02                        JRUGE LCD_PDB_J3
A256 0C 05                        JRA LCD_PDB_J4
A258 2F F6      LCD_PDB_J3        ADDA #0xF6              ; subtract 10 (A = A - 10)
A25A 05                           INCX
A25B 0C F5                        JRA LCD_PDB_L3
A25D 24         LCD_PDB_J4        PSHA                    ; Save remaining value (0..9) on stack
A25E 2A 1F F4                     LDA XL                  ; Load X (tens counter) into A
A261 06 A2 13                     JSR LCD_PrintHexDigit   ; Print ten digit as hex (0..9)
A264 25                           POPA                    ; restore remaining value (0..9) into A
A265 06 A2 13                     JSR LCD_PrintHexDigit
A268 07                           RTS

                ;------------------------------------------------------------
                ; Print 16-bit number in decimal (0..65535)
                ; Input:
                ;    X = number to print
                ;------------------------------------------------------------
                ;LCD_PrintDec16 CLRA                    ; -------- 10000 digit --------
                ;PD16_L1        CPX #0x2710             ; Compare with 10000
                ;               JRULT PD16_J1
                ;               SUBX #0x2710
                ;               INCA
                ;               JRA PD16_L1
                ;PD16_J1        PSHX
                ;               JSR LCD_PrintHexDigit
                ;               PULX
                ;               CLRA                    ; -------- 1000 digit --------
                ;PD16_L2        CPX 0x03E8              ; Compare with 1000
                ;               JRULT PD16_J2
                ;               SUBX #0x03E8
                ;               INCA
                ;               JRA PD16_L2
                ;PD16_J2        PSHX
                ;               JSR LCD_PrintHexDigit
                ;               PULX
                ;               CLRA                    ; -------- 100 digit --------
                ;PD16_L3        CPX #0x64               ; Compare with 100
                ;               JRULT PD16_J3
                ;               SUBX #0x64
                ;               INCA
                ;               JRA PD16_L3
                ;PD16_J3        PSHX
                ;               JSR LCD_PrintHexDigit
                ;               PULX
                ;               CLRA                    ; -------- 10 digit --------
                ;PD16_L4        CPX #0x0A               ; Compare with 10
                ;               JRULT PD16_J4
                ;               SUBX #0x0A
                ;               INCA
                ;               JRA PD16_L4
                ;PD16_J4        PSHX
                ;               JSR LCD_PrintHexDigit
                ;               PULX
                ;               TXA                     ; -------- 1 digit --------
                ;               JSR LCD_PrintHexDigit
                ;               RTS

                         ; --------------------------------------------------------------------
