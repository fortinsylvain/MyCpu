                               ; TEST EXECUTION FROM RAM
                               ; Copy a block of code from EEPROM to RAM
                               ; then call to execute this block in RAM. Resume execution from EEPROM
9D24 30 80                     LDA #0x80
9D26 19                        NOTA
9D27 31 78 00                  STA LEDPORT ; Output to LED port
9D2A 32 9D 4B                  JMP BLKCODEEND   ; We skip the nex block of code to be copied in RAM
                               ; Simple 8 bit multiplication test code
9D2D 30 56      BLKCODESTART   LDA #0x56   ; 86 * 171 = 14706   (0x56 * 0xAB = 0x3972)
9D2F 31 00 0F                  STA ?b0
9D32 30 AB                     LDA #0xAB
9D34 31 00 0E                  STA ?b1
9D37 06 A1 6F                  JSR ?mul8_w1_b1_b0
9D3A 2A 00 0C                  LDA ?b3
9D3D 21 39                     TEQA #0x39
9D3F 2B FF B0                  JNE FAIL
9D42 2A 00 0D                  LDA ?b2
9D45 21 72                     TEQA #0x72
9D47 2B FF B0                  JNE FAIL
9D4A 07                        RTS
                               ; Copy the Block of code from EEPROM to RAM
9D4B 04 9D 2D   BLKCODEEND     LDX #BLKCODESTART ; Load address of BLKCODESTART
9D4E 16 00 0E                  STX ?b1           ; Store this adddress in ?b1:?b0
                RAMDESTSTART   EQU 0x1000
9D51 04 10 00                  LDX #RAMDESTSTART ; Load address of RAM destination
9D54 16 00 0C                  STX ?b3           ; Store this adddress in ?b3:?b2
                               ; copy a byte from source to destination
9D57 1B 0E      LOOPTST47      LDX s.?b1         ; Load X with source address in ?b1:?b0
9D59 1A 9D 4B                  CMPX #BLKCODEEND  ; Check if last byte copied
9D5C 2C 9D 6D                  JEQ ENDCOPYTST47  ; if yes then quit copy loop
9D5F 0A                        LDA (X)           ; Load byte pointed by X
9D60 05                        INCX
9D61 16 00 0E                  STX ?b1
9D64 1B 0C                     LDX s.?b3         ; Load X with destination address in ?b3:?b2
9D66 0B                        STA (X)           ; Store byte to address pointed by X
9D67 05                        INCX
9D68 16 00 0C                  STX ?b3
9D6B 0C EA                     JRA LOOPTST47
9D6D 06 10 00   ENDCOPYTST47   JSR RAMDESTSTART ; Jump to ram for code execution

                            ; ---------------------------------------
                            ; 32-bit Fibonacci using library routines
                            ; l2 = F(n), l1 = F(n-1), l0 = F(n-2)
                            ; ---------------------------------------
9D70 30 81                  LDA #0x81
9D72 19                     NOTA
9D73 31 78 00               STA LEDPORT
                LOOPCNT     EQU 0x0100           ; Loop counter storage
                FIBNUMB     EQU 0x1000           ; Output buffer for Fibonacci numbers
                            ; Initialize Fibonacci state
9D76 06 9E 84               JSR ?clear32_l0      ; F(0) = 0
9D79 06 9F 0C               JSR ?set32_l1_to_1   ; F(1) = 1
9D7C 06 9E A0               JSR ?clear32_l2
                            ; Output buffer
9D7F 04 10 00               LDX #FIBNUMB
9D82 06 9F 6C               JSR ?store32_l0      ; F(0)
9D85 05                     INCX                 ; advance to next 32-bit slot
9D86 06 9F 80               JSR ?store32_l1      ; F(1)
9D89 05                     INCX                 ; advance to next 32-bit slot
                            ; Loop counter
                            ; F(47)=2,971,215,073  fit in 32 bits
                            ; F(48)=4,807,526,976  exceed 32 bits
9D8A 30 2D                  LDA #0x2D   ; 47 - 2 = 45  iterations (0x2D)
9D8C 31 01 00               STA LOOPCNT
9D8F 06 A0 D5   FIB32_LOOP  JSR ?add32_l2_l1_l0  ; l2 = l1 + l0
9D92 06 9F 94               JSR ?store32_l2      ; store F(n)
9D95 05                     INCX                 ; advance to next 32-bit slot
                            ; rotate registers
9D96 06 A0 07               JSR ?mov32_l0_l1     ; l0 = l1
9D99 06 A0 6B               JSR ?mov32_l1_l2     ; l1 = l2
                            ;  DEC LOOPCNT    ; i dont have a DEC direct instruction for now
9D9C 2A 01 00               LDA LOOPCNT
9D9F 20                     DECA
9DA0 31 01 00               STA LOOPCNT
9DA3 21 00                  TEQA #0x00
9DA5 2B 9D 8F               JNE FIB32_LOOP
                            ; End of fibonacci number computation
                            ; Verify Fibonacci numbers stored in memory
9DA8 30 82                  LDA #0x82
9DAA 19                     NOTA
9DAB 31 78 00               STA LEDPORT             
                            ; Memory layout:
                            ;   FIBNUMB: F(0), F(1), F(2), ...
                            ; Registers:
                            ;   l0 = previous-previous (F(n-2))
                            ;   l1 = previous          (F(n-1))
                            ;   l2 = current from mem  (F(n))
                            ;-----------------------------------------------
9DAE 04 10 00   FIB_VERIFY  LDX #FIBNUMB         ; pointer to first Fibonacci number
                            ; Load first two Fibonacci numbers from memory
9DB1 06 9F 1C               JSR ?load32_l0       ; l0 = F(0)
9DB4 05                     INCX  
9DB5 06 9F 30               JSR ?load32_l1       ; l1 = F(1)
9DB8 05                     INCX  
                            ; Loop counter
                            ; F(47)=2,971,215,073  fit in 32 bits
                            ; F(48)=4,807,526,976  exceed 32 bits
9DB9 30 2D                  LDA #0x2D   ; 47 - 2 = 45  iterations (0x2D)
9DBB 31 01 00               STA LOOPCNT
9DBE 06 9F 44   VERIFY_LOOP JSR ?load32_l2       ; Load next Fibonacci number from memory into l2
9DC1 05                     INCX  
9DC2 06 A0 FA               JSR ?add32_l3_l1_l0  ; Compute sum l0 + l1 → l3
9DC5 06 A1 45               JSR ?cmp32_l3_l2     ; Compare computed sum with loaded number
9DC8 2B FF B0               JNE FAIL
9DCB 06 A0 07               JSR ?mov32_l0_l1     ; Rotate registers for next iteration
9DCE 06 A0 6B               JSR ?mov32_l1_l2
9DD1 2A 01 00               LDA LOOPCNT          ; Decrement loop counter
9DD4 2F FF                  ADDA #0xFF         ; decrement
9DD6 31 01 00               STA LOOPCNT
9DD9 21 00                  TEQA #0x00
9DDB 2B 9D BE               JNE VERIFY_LOOP
                            ; End of fibonacci number verification
9DDE 30 83                  LDA #0x83
9DE0 19                     NOTA
9DE1 31 78 00               STA LEDPORT 

