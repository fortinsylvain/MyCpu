8659 19                  NOTA
865A 31 78 00            STA LEDPORT ; Output to LED port
865D 26                  CLRA        ; Clear Carry
865E 31 1F FB            STA CARRY
8661 31 00 0F            STA ?b0
8664 14 00 0F            RRC ?b0
8667 2A 00 0F            LDA ?b0
866A 21 00               TEQA #0x00
866C 2B FF B0            JNE FAIL
866F 26                  CLRA        ; Clear Carry
