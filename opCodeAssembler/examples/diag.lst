                         ; --------------------------------------------------------------------
                         ; OP.29 ADDA 0x****  
                         ; ADD A WITH BYTE AT ADDRESS, C UPDATE
                         ; --------------------------------------------------------------------
939A 30 29      TSTOP29  LDA #0x29
939C 19                  NOTA
939D 31 78 00            STA LEDPORT ; Output to LED port
93A0 30 5F               LDA #0x5F   ; Store a value in RAM
93A2 31 01 23            STA 0x0123   
93A5 30 63               LDA #0x63
93A7 29 01 23            ADDA 0x0123 ; Add to A the byte at address location
93AA 21 C2               TEQA #0xC2  ; Check the sum
93AC 2B FF B0            JNE FAIL    ; Jump if result not good
93AF 2A 1F FB            LDA CARRY   ; Read the Carry Status
93B2 21 00               TEQA #0x00  ; No carry expected then C should be '0'
93B4 2B FF B0            JNE FAIL    ; Error if carry is set

93B7 30 AC               LDA #0xAC   ; Store another value in RAM
93B9 31 10 56            STA 0x1056   
93BC 30 D9               LDA #0xD9
93BE 29 10 56            ADDA 0x1056 ; Add to A the byte at address location
93C1 21 85               TEQA #0x85  ; Check the sum LSB
93C3 2B FF B0            JNE FAIL    ; Jump if result not as expected
93C6 2A 1F FB            LDA CARRY   ; Read the Carry Status
93C9 21 01               TEQA #0x01  ; The Carry Status bit is expected to be '1' with <7:1> set to '0'
93CB 2B FF B0            JNE FAIL    ; Error if different
