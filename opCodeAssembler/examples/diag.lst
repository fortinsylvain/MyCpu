867C 21 00               TEQA #0x00
867E 2B FF B0            JNE FAIL
8681 30 AA               LDA #0xAA   ; Test shifting
8683 31 00 0F            STA ?b0
8686 14 00 0F            RRC ?b0
8689 2A 00 0F            LDA ?b0
868C 21 55               TEQA #0x55
868E 2B FF B0            JNE FAIL
8691 30 01               LDA #0x01   ; Test transfer of bit <0> to carry
8693 31 00 0F            STA ?b0
8696 14 00 0F            RRC ?b0
8699 2A 1F FB            LDA CARRY
869C 21 01               TEQA #0x01
869E 2B FF B0            JNE FAIL
86A1 26                  CLRA        ; Test A become 0 after shifting when carry is 0
86A2 31 1F FB            STA CARRY   ; insure carry is clear
86A5 30 01               LDA #0x01   ; set bit <0> to '1'
86A7 31 00 0F            STA ?b0
86AA 14 00 0F            RRC ?b0
86AD 2A 00 0F            LDA ?b0
86B0 21 00               TEQA #0x00
86B2 2B FF B0            JNE FAIL
86B5 26                  CLRA   ; Test bit <0> goes to bit <7> after 2 RRCA
86B6 31 1F FB            STA CARRY   ; insure carry is clear
86B9 30 01               LDA #0x01
86BB 31 00 0F            STA ?b0
86BE 14 00 0F            RRC ?b0
86C1 14 00 0F            RRC ?b0
86C4 2A 00 0F            LDA ?b0
86C7 21 80               TEQA #0x80
86C9 2B FF B0            JNE FAIL
86CC 14 00 0F            RRC ?b0     ; continue rotating this bit
86CF 2A 00 0F            LDA ?b0
86D2 21 40               TEQA #0x40
86D4 2B FF B0            JNE FAIL
86D7 14 00 0F            RRC ?b0
86DA 2A 00 0F            LDA ?b0
