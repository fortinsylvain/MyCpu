86FE 21 04               TEQA #0x04
8700 2B FF B0            JNE FAIL
8703 14 00 0F            RRC ?b0
8706 2A 00 0F            LDA ?b0
8709 21 02               TEQA #0x02
870B 2B FF B0            JNE FAIL
870E 14 00 0F            RRC ?b0
8711 2A 00 0F            LDA ?b0
8714 21 01               TEQA #0x01
8716 2B FF B0            JNE FAIL
8719 14 00 0F            RRC ?b0
871C 2A 00 0F            LDA ?b0
871F 21 00               TEQA #0x00
8721 2B FF B0            JNE FAIL
8724 14 00 0F            RRC ?b0
8727 2A 00 0F            LDA ?b0
872A 21 80               TEQA #0x80
872C 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.15 SRL 0x****   Shift Right Logical on Address
                         ;                    0 -> b7 b6 b5 b4 b3 b2 b1 b0 -> C
                         ; --------------------------------------------------------------------
872F 30 15      TSTOP15  LDA #0x15
8731 19                  NOTA
8732 31 78 00            STA LEDPORT ; Output to LED port
8735 30 A5               LDA #0xA5
8737 31 00 0F            STA ?b0
