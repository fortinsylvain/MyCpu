                         ; --------------------------------------------------------------------
                         ; OP.0F 
                         ; JRNC Jump Relatif if Not Carry
                         ; --------------------------------------------------------------------
84DC 30 0F      TSTOP0F  LDA #0x0F
84DE 19                  NOTA
84DF 31 78 00            STA LEDPORT ; Output to LED port
84E2 26                  CLRA   ; Clear carry
84E3 31 1F FB            STA CARRY
84E6 0F 03               JRNC TST0F_0
84E8 32 FF B0            JMP FAIL
84EB 30 01      TST0F_0  LDA #0x01   ; Set carry
84ED 31 1F FB            STA CARRY
84F0 0F 03               JRNC TST0F_1
84F2 32 84 F8            JMP TST0F_2
84F5 32 FF B0   TST0F_1  JMP FAIL
84F8 09         TST0F_2  NOP
                         ; --------------------------------------------------------------------
                         ; OP.10  RRCA   Rotate Right Logical Reg A through Carry 
                         ;               C -> b7 b6 b5 b4 b3 b2 b1 b0 -> C  
                         ; --------------------------------------------------------------------
84F9 30 10      TSTOP10  LDA #0x10
84FB 19                  NOTA
84FC 31 78 00            STA LEDPORT ; Output to LED port
84FF 26                  CLRA        ; Clear Carry
8500 31 1F FB            STA CARRY
8503 10                  RRCA
8504 21 00               TEQA #0x00
8506 2B FF B0            JNE FAIL
8509 26                  CLRA        ; Clear Carry
850A 31 1F FB            STA CARRY
850D 10                  RRCA
850E 2A 1F FB            LDA CARRY
8511 21 00               TEQA #0x00
8513 2B FF B0            JNE FAIL
8516 30 AA               LDA #0xAA   ; Test shifting
8518 10                  RRCA
8519 21 55               TEQA #0x55
851B 2B FF B0            JNE FAIL
851E 30 01               LDA #0x01   ; Test transfer of bit <0> to carry
8520 10                  RRCA
8521 2A 1F FB            LDA CARRY
8524 21 01               TEQA #0x01
8526 2B FF B0            JNE FAIL
8529 26                  CLRA        ; Test A become 0 after shifting when carry is 0
852A 31 1F FB            STA CARRY   ; insure carry is clear
852D 30 01               LDA #0x01   ; set bit <0> to '1'
852F 10                  RRCA
8530 21 00               TEQA #0x00
8532 2B FF B0            JNE FAIL
8535 26                  CLRA        ; Test bit <0> goes to bit <7> after 2 RRCA
8536 31 1F FB            STA CARRY   ; insure carry is clear
8539 30 01               LDA #0x01
853B 10                  RRCA
853C 10                  RRCA
853D 21 80               TEQA #0x80
853F 2B FF B0            JNE FAIL
8542 10                  RRCA        ; continue rotating this bit
8543 21 40               TEQA #0x40
8545 2B FF B0            JNE FAIL
8548 10                  RRCA
8549 21 20               TEQA #0x20
854B 2B FF B0            JNE FAIL
854E 10                  RRCA
854F 21 10               TEQA #0x10
8551 2B FF B0            JNE FAIL
8554 10                  RRCA
8555 21 08               TEQA #0x08
8557 2B FF B0            JNE FAIL
855A 10                  RRCA
855B 21 04               TEQA #0x04
855D 2B FF B0            JNE FAIL
8560 10                  RRCA
8561 21 02               TEQA #0x02
8563 2B FF B0            JNE FAIL
8566 10                  RRCA
8567 21 01               TEQA #0x01
8569 2B FF B0            JNE FAIL
856C 10                  RRCA
856D 21 00               TEQA #0x00
856F 2B FF B0            JNE FAIL
8572 10                  RRCA
8573 21 80               TEQA #0x80
8575 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.11  RCF   Reset Carry Flag   C <- 0
                         ; --------------------------------------------------------------------
8578 30 11      TSTOP11  LDA #0x11
857A 19                  NOTA
857B 31 78 00            STA LEDPORT ; Output to LED port
857E 30 01               LDA #0x01   ; Set carry flag to 1
8580 31 1F FB            STA CARRY
8583 11                  RCF         ; Reset Carry Flag 
8584 2A 1F FB            LDA CARRY   ; Check carry is now cleared
8587 21 00               TEQA #0x00
8589 2B FF B0            JNE FAIL
858C 11                  RCF         ; Do again a Reset Carry Flag 
858D 2A 1F FB            LDA CARRY   ; Check carry is still cleared
8590 21 00               TEQA #0x00
8592 2B FF B0            JNE FAIL
8595 30 A5               LDA #0xA5   ; Check register A is not affected by a Reset Carry Flag
8597 11                  RCF         ; Reset Carry Flag
8598 21 A5               TEQA #0xA5  ; If A value not same then fail
859A 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.12  SCF   Set Carry Flag   C <- 1
                         ; --------------------------------------------------------------------
859D 30 12      TSTOP12  LDA #0x12
859F 19                  NOTA
85A0 31 78 00            STA LEDPORT ; Output to LED port
85A3 26                  CLRA        ; Clear carry flag
85A4 31 1F FB            STA CARRY
85A7 12                  SCF         ; Set Carry Flag 
85A8 2A 1F FB            LDA CARRY   ; Check carry is set
85AB 21 01               TEQA #0x01
85AD 2B FF B0            JNE FAIL
85B0 12                  SCF         ; Set Carry Flag again
85B1 2A 1F FB            LDA CARRY   ; Check carry is still set
85B4 21 01               TEQA #0x01
85B6 2B FF B0            JNE FAIL
85B9 30 BE               LDA #0xBE   ; Check register A is not affected by a Set Carry Flag
85BB 12                  SCF         ; Set Carry Flag
85BC 21 BE               TEQA #0xBE  ; If A value not same then fail
85BE 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.13  DECXL   Decrement XL   E updated
                         ; --------------------------------------------------------------------
85C1 30 13      TSTOP13  LDA #0x13
85C3 19                  NOTA
85C4 31 78 00            STA LEDPORT ; Output to LED port
85C7 04 FF FF            LDX #0xFFFF
85CA 13                  DECXL
85CB 2A 1F F3            LDA XH
