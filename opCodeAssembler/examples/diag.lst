                         ; --------------------------------------------------------------------
                         ; OP.2B JNE 0x****  
                         ; JUMP IF E=0
                         ; Only a partial validation because i do not have symbolic address
                         ; processing in the assembler program.
                         ; --------------------------------------------------------------------
9499 30 2B      TSTOP2B  LDA #0x2B
949B 19                  NOTA
949C 31 78 00            STA LEDPORT ; Output to LED port
949F 30 6D               LDA #0x6D   ; Load a value in A
94A1 21 6D               TEQA #0x6D  ; Compare with the same value
94A3 2B FF B0            JNE FAIL    ; Error if values are different
94A6 30 10               LDA #0x10
94A8 21 10               TEQA #0x10
94AA 2B FF B0            JNE FAIL
94AD 30 01               LDA #0x01
94AF 21 01               TEQA #0x01
94B1 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.2C JEQ 0x****
                         ; JUMP IF E=1
                         ; --------------------------------------------------------------------
94B4 30 2C      TST2C    LDA #0x2C
94B6 19                  NOTA
94B7 31 78 00            STA LEDPORT ; Output to LED port
94BA 30 7A               LDA #0x7A   ; Load a value in A
94BC 21 28               TEQA #0x28  ; Compare with a different value
94BE 2C FF B0            JEQ FAIL    ; If appear identical then it's and error
94C1 30 FE               LDA #0xFE   ; Again with adifference 
94C3 21 FF               TEQA #0xFF
94C5 2C FF B0            JEQ FAIL 
94C8 30 01               LDA #0x01   ; Another with difference
94CA 21 10               TEQA #0x10
94CC 2C FF B0            JEQ FAIL
94CF 30 AB               LDA #0xAB   ; Now compare when values are identical
94D1 21 AB               TEQA #0xAB
94D3 2C 94 D9            JEQ TST2C_1 ; Testing if equal?
94D6 32 FF B0            JMP FAIL    ; Result say both are not equal then it's a failure
94D9 26         TST2C_1  CLRA        ; Result say the values are identical so we are passing
94DA 21 00               TEQA #0x00
94DC 2C 94 E2            JEQ TST2C_2 ; Testing if equal?
94DF 32 FF B0            JMP FAIL    ; if different then it's a failure
94E2 30 01      TST2C_2  LDA #0x01
94E4 21 01               TEQA #0x01
94E6 2C 94 EC            JEQ TST2C_3 ; Testing if equal?
94E9 32 FF B0            JMP FAIL    ; if different then it's a failure
94EC 30 02      TST2C_3  LDA #0x02
94EE 21 02               TEQA #0x02
94F0 2C 94 F6            JEQ TST2C_4 ; Testing if equal?
94F3 32 FF B0            JMP FAIL    ; if different then it's a failure
94F6 30 04      TST2C_4  LDA #0x04
94F8 21 04               TEQA #0x04
94FA 2C 95 00            JEQ TST2C_5 ; Testing if equal?
94FD 32 FF B0            JMP FAIL    ; if different then it's a failure
9500 30 08      TST2C_5  LDA #0x08
9502 21 08               TEQA #0x08
9504 2C 95 0A            JEQ TST2C_6 ; Testing if equal?
9507 32 FF B0            JMP FAIL    ; if different then it's a failure
950A 30 10      TST2C_6  LDA #0x10
950C 21 10               TEQA #0x10
950E 2C 95 14            JEQ TST2C_7 ; Testing if equal?
9511 32 FF B0            JMP FAIL    ; if different then it's a failure
9514 30 20      TST2C_7  LDA #0x20
9516 21 20               TEQA #0x20
9518 2C 95 1E            JEQ TST2C_8 ; Testing if equal?
951B 32 FF B0            JMP FAIL    ; if different then it's a failure         
951E 30 40      TST2C_8  LDA #0x40
9520 21 40               TEQA #0x40
9522 2C 95 28            JEQ TST2C_9 ; Testing if equal?
9525 32 FF B0            JMP FAIL    ; if different then it's a failure         
9528 30 80      TST2C_9  LDA #0x80
952A 21 80               TEQA #0x80
952C 2C 95 32            JEQ TST2C_10 ; Testing if equal?
952F 32 FF B0            JMP FAIL    ; if different then it's a failure         
9532 09         TST2C_10 NOP
                         ; --------------------------------------------------------------------
                         ; OP.2D CMPA #0x**
                         ; Compare A with Imm (A-Imm)    A unchanged, E and C are updated
                         ; Note: CMPA → updates E and C  but  TEQA → updates E
                         ; --------------------------------------------------------------------
9533 30 2D      TSTOP2D  LDA #0x2D
9535 19                  NOTA
9536 31 78 00            STA LEDPORT ; Output to LED port
9539 30 CA               LDA #0xCA   ;  -- Compare with identical value --
953B 2D CA               CMPA #0xCA
                         ;TEQA #0xCA  ; Verify A is unchanged  CAN'T DO THIS IT WILL OVERWRITE E
                         ;JNE FAIL
953D 2A 1F FA            LDA EQUAL   ; Inspect EQUAL STATUS 
9540 21 01               TEQA #0x01  ; Verify bit<0> E = '1' and all others bits <7:1> are '0'
9542 2B FF B0            JNE FAIL
9545 2A 1F FB            LDA CARRY   ; Inspect CARRY STATUS
9548 21 01               TEQA #0x01  ; Verify bit<0> C = '1' and all others bits <7:1> are '0'
954A 2B FF B0            JNE FAIL
954D 30 B5               LDA #0xB5   ;  -- Compare with different value (A > Imm) --
954F 2D 4D               CMPA #0x4D
                         ;TEQA #0xB5  ; Verify A is unchanged  CAN'T DO THIS IT WILL OVERWRITE E
                         ;JNE FAIL
9551 2A 1F FA            LDA EQUAL   ; Inspect EQUAL STATUS
9554 21 00               TEQA #0x00  ; Verify bit<0> E = '0'
9556 2B FF B0            JNE FAIL
9559 2A 1F FB            LDA CARRY   ; Inspect CARRY STATUS
955C 21 01               TEQA #0x01  ; Verify bit<0> C = '1'
955E 2B FF B0            JNE FAIL
9561 30 5B               LDA #0x5B   ;  -- Compare with different value (A < Imm) --
9563 2D EE               CMPA #0xEE
                         ;TEQA #0x5B  ; Verify A is unchanged  CAN'T DO THIS IT WILL OVERWRITE E
                         ;JNE FAIL
9565 2A 1F FA            LDA EQUAL   ; Inspect EQUAL STATUS
9568 21 00               TEQA #0x00  ; Verify bit<0> E = '0'
956A 2B FF B0            JNE FAIL
956D 2A 1F FB            LDA CARRY   ; Inspect CARRY STATUS
9570 21 00               TEQA #0x00  ; Verify bit<0> C = '0'
9572 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.2E ADCA #0x**
                         ; REG A = REG A + IMMEDIATE BYTE + CARRY (C)   
                         ; CARRY STATUS (C) IS UPDATED
                         ; --------------------------------------------------------------------
9575 30 2E      TSTOP2E  LDA #0x2E
9577 19                  NOTA
9578 31 78 00            STA LEDPORT ; Output to LED port
957B 26                  CLRA        ; Clear CARRY (C)
957C 31 1F FB            STA CARRY      
957F 30 45               LDA #0x45
9581 2E 5B               ADCA #0x5B
9583 21 A0               TEQA #0xA0  ; Verify summ
9585 2B FF B0            JNE FAIL
9588 2A 1F FB            LDA CARRY   ; Check carry
958B 21 00               TEQA #0x00  ; Should be clear
958D 2B FF B0            JNE FAIL

9590 30 01               LDA #0x01   ; Set CARRY (C)
9592 31 1F FB            STA CARRY
9595 30 56               LDA #0x56
9597 2E 6D               ADCA #0x6D
9599 21 C4               TEQA #0xC4   ; Verify summ
959B 2B FF B0            JNE FAIL
959E 2A 1F FB            LDA CARRY   ; Check carry
95A1 21 00               TEQA #0x00  ; Should be clear
95A3 2B FF B0            JNE FAIL

95A6 26                  CLRA        ; Clear CARRY (C)
95A7 31 1F FB            STA CARRY
95AA 30 7F               LDA #0x7F
95AC 2E DE               ADCA #0xDE
95AE 21 5D               TEQA #0x5D  ; Verify summ
95B0 2B FF B0            JNE FAIL
95B3 2A 1F FB            LDA CARRY   ; Check carry
95B6 21 01               TEQA #0x01  ; Should be set
95B8 2B FF B0            JNE FAIL

95BB 30 01               LDA #0x01   ; Set CARRY (C)
95BD 31 1F FB            STA CARRY
95C0 30 FF               LDA #0xFF
95C2 2E FF               ADCA #0xFF
95C4 21 FF               TEQA #0xFF  ; Verify summ
95C6 2B FF B0            JNE FAIL
95C9 2A 1F FB            LDA CARRY   ; Check carry
95CC 21 01               TEQA #0x01  ; Should be set
95CE 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.2F ADDA #0x**
                         ; ACCA+M>ACCA     C UPDATED
