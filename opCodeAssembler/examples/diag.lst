                ; -----------------------------------------------------------------
                ; Homebrew MyCPU diagnostic program
                ; Author: Sylvain Fortin sylfortin71@hotmail.com
                ; Date : 8 march 2026
                ; Documentation : diag.asm is a test program that verifying every 
                ;                 assembler instructions of MyCPU.
                ; Memory map of the computer
                ; 0x0000 - 0x7FFF Total RAM space
                ; 0x00A0 - 0x00FF Stack
                ; 0x7800 - 0x7BFF LED_PORT 
                ; 0x7C00 - 0x7FFF LCD
                ; 0x8000 - 0xFFFF EEPROM for application program
                ; -----------------------------------------------------------------

                ; virtual registers
                ;-----------------------------------------------------------------------------
                ; ?b15 ?b14 ?b13 ?b12 | ?b11 ?b10 ?b9 ?b8 | ?b7 ?b6 ?b5 ?b4 | ?b3 ?b2 ?b1 ?b0 |  8 bits
                ;    ?w7       ?w6    |    ?w5      ?w4   |   ?w3     ?w2   |   ?w1     ?w0   | 16 bits
                ;         ?l3         |         ?l2       |       ?l1       |       ?l0       | 32 bits
                ;-----------------------------------------------------------------------------

                ?b15     EQU 0x0000
                ?b14     EQU 0x0001
                ?b13     EQU 0x0002
                ?b12     EQU 0x0003
                ?b11     EQU 0x0004
                ?b10     EQU 0x0005
                ?b9      EQU 0x0006
                ?b8      EQU 0x0007
                ?b7      EQU 0x0008
                ?b6      EQU 0x0009
                ?b5      EQU 0x000A
                ?b4      EQU 0x000B
                ?b3      EQU 0x000C
                ?b2      EQU 0x000D
                ?b1      EQU 0x000E
                ?b0      EQU 0x000F

                ?w7      EQU 0x0000  ; ?b15:?b14
                ?w6      EQU 0x0002  ; ?b13:?b12
                ?w5      EQU 0x0004  ; ?b11:?b10
                ?w4      EQU 0x0006  ; ?b9:?b8
                ?w3      EQU 0x0008  ; ?b7:?b6
                ?w2      EQU 0x000A  ; ?b5:?b4
                ?w1      EQU 0x000C  ; ?b3:?b2
                ?w0      EQU 0x000E  ; ?b1:?b0

                ?l3      EQU 0x0000  ; ?b15,?b14,?b13,?b12
                ?l2      EQU 0x0004  ; ?b11,?b10,?b9,?b8
                ?l1      EQU 0x0008  ; ?b7,?b6,?b5,?b4
                ?l0      EQU 0x000C  ; ?b3,?b2,?b1,?b0

                ; RAM Reserved location
                TEMP0    EQU 0x1FEC  ; TEMP0
                TEMP1    EQU 0x1FED  ; TEMP1
                TEMP2    EQU 0x1FEE  ; TEMP2
                TEMP3    EQU 0x1FEF  ; TEMP3
                SP       EQU 0x1FF0  ; SP      Stack Pointer 8 bit
                JSH      EQU 0x1FF1  ; JSH     Temporary storage for JSR MSB address
                JSL      EQU 0x1FF2  ; JSL          "       "     "   "  LSB    "
                XH       EQU 0x1FF3  ; X MSB   X Register MSB
                XL       EQU 0x1FF4  ; X LSB   X Register LSB
                EQUAL    EQU 0x1FFA  ; E       bit<0> Equal Status bit
                CARRY    EQU 0x1FFB  ; C       bit<0> Carry Status bit
                REG_A    EQU 0x1FFC  ; A       A Register
                IPH      EQU 0x1FFE  ; IPH	    Instruction Pointer MSB
                IPL      EQU 0x1FFF  ; IPL          "         "    LSB

                ; Diagnostic program variable
                DIAGLOOPCOUNTER_MSB EQU 0x01E0  ; MSB of loop counter for diagnostics
                DIAGLOOPCOUNTER_LSB EQU 0x01E1  ; LSB
                DIAGTST_MSB         EQU 0x01E2  ; MSB of test variable
                DIAGTST_LSB         EQU 0x01E3  ; LSB 
                DIAGTST2_MSB        EQU 0x1EFF  ; MSB of test variable2
                DIAGTST2_LSB        EQU 0x1F00  ; LSB 

                ;--------------------------------------------
                ; LED PORT
                ;--------------------------------------------
                LEDPORT  EQU 0x7800  ; PORT for the LED

                ;--------------------------------------------
                ; LCD Memory-Mapped I/O Addresses
                ;--------------------------------------------
                LCD_CMD  EQU 0x7C00
                LCD_DATA EQU 0x7C01

                ; Diagnostic program start
                         ORG/0x8000  ; EEPROM Start of the diagnostic program
8000 26         START    CLRA        ; Initialize diagnostic loop counter
8001 31 01 E0            STA DIAGLOOPCOUNTER_MSB
8004 31 01 E1            STA DIAGLOOPCOUNTER_LSB
8007 26         LOOPDIAG CLRA        ; Clear LED
8008 19                  NOTA
8009 31 78 00            STA LEDPORT ; Output to LED port         
                         ; --------------------------------------------------------------------
                         ; Test Carry Status bit integrity
                         ; --------------------------------------------------------------------
800C 30 01      TST01    LDA #0x01
800E 19                  NOTA
800F 31 78 00            STA LEDPORT ; Output to LED port
8012 26                  CLRA 
8013 31 1F FB            STA CARRY   ; Write 0 to carry bit <0>
8016 2A 1F FB            LDA CARRY   ; Read Carry Status
8019 21 00               TEQA #0x00
801B 2B FF B0            JNE FAIL
801E 30 01               LDA #0x01
8020 31 1F FB            STA CARRY   ; Write 1 to carry bit <0>
8023 2A 1F FB            LDA CARRY   ; Read Carry Status
8026 21 01               TEQA #0x01
8028 2B FF B0            JNE FAIL
802B 26                  CLRA
802C 31 1F FB            STA CARRY   ; Write 0 to carry bit <0>
802F 2A 1F FB            LDA CARRY   ; Read Carry Status
8032 21 00               TEQA #0x00
8034 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; Test Equal Status bit integrity
                         ; --------------------------------------------------------------------
8037 30 02      TST02    LDA #0x02
8039 19                  NOTA
803A 31 78 00            STA LEDPORT ; Output to LED port
803D 26                  CLRA
803E 31 1F FA            STA EQUAL   ; Write 0 to Equal Status bit <0>
8041 2A 1F FA            LDA EQUAL   ; Read Equal Status
8044 21 00               TEQA #0x00
8046 2B FF B0            JNE FAIL
8049 30 01               LDA #0x01
804B 31 1F FA            STA EQUAL   ; Write 1 to Equal Status bit <0>
804E 2A 1F FA            LDA EQUAL   ; Read Equal Status
8051 21 01               TEQA #0x01
8053 2B FF B0            JNE FAIL
8056 26                  CLRA
8057 31 1F FA            STA EQUAL   ; Write 0 to Equal Status bit <0>
805A 2A 1F FA            LDA EQUAL   ; Read Equal Status
805D 21 00               TEQA #0x00
805F 2B FF B0            JNE FAIL

                         ; --------------------------------------------------------------------
                         ; OP.03 INCA  A = A + 1  INCREMENT REGISTRE A
                         ; E UPDATE, C unchanged
                         ; --------------------------------------------------------------------
8062 30 03      TSTOP03  LDA #0x03
8064 19                  NOTA
8065 31 78 00            STA LEDPORT ; Output to LED port
8068 26                  CLRA
8069 03                  INCA
806A 21 01               TEQA #0x01
806C 2B FF B0            JNE FAIL
806F 30 01               LDA #0x01
8071 03                  INCA
8072 21 02               TEQA #0x02
8074 2B FF B0            JNE FAIL
8077 30 7C               LDA #0x7C
8079 03                  INCA
807A 03                  INCA
807B 03                  INCA
807C 03                  INCA
807D 03                  INCA
807E 03                  INCA
807F 03                  INCA
8080 03                  INCA
8081 03                  INCA
8082 03                  INCA
8083 21 86               TEQA #0x86
8085 2B FF B0            JNE FAIL
8088 30 FE               LDA #0xFE
808A 03                  INCA
808B 21 FF               TEQA #0xFF
808D 2B FF B0            JNE FAIL
8090 30 FF               LDA #0xFF
8092 03                  INCA
8093 21 00               TEQA #0x00
8095 2B FF B0            JNE FAIL
8098 30 FF               LDA #0xFF
809A 03                  INCA
809B 03                  INCA
809C 21 01               TEQA #0x01
809E 2B FF B0            JNE FAIL
80A1 03                  INCA
80A2 03                  INCA
80A3 03                  INCA
80A4 03                  INCA
80A5 21 05               TEQA #0x05
80A7 2B FF B0            JNE FAIL
80AA 03                  INCA
80AB 03                  INCA
80AC 03                  INCA
80AD 03                  INCA
80AE 03                  INCA
80AF 03                  INCA
80B0 03                  INCA
80B1 03                  INCA
80B2 21 0D               TEQA #0x0D
80B4 2B FF B0            JNE FAIL
80B7 26                  CLRA   ; Test Carry unchanged
80B8 31 1F FB            STA CARRY   ; Clear Carry 
80BB 30 FF               LDA #0xFF
80BD 03                  INCA
80BE 2A 1F FB            LDA CARRY   ; Read Carry bit <0>
80C1 21 00               TEQA #0x00  ; Expecting C=0 and <7:1> = 0
80C3 2B FF B0            JNE FAIL
80C6 30 01               LDA #0x01   ; Set Carry 
80C8 31 1F FB            STA CARRY   
80CB 30 EB               LDA #0xEB
80CD 03                  INCA
80CE 2A 1F FB            LDA CARRY   ; Read Carry bit <0>
80D1 21 01               TEQA #0x01  ; Expecting C=1 and <7:1> = 0
80D3 2B FF B0            JNE FAIL
80D6 30 FE               LDA #0xFE   ; Test Equal (Set when result is 0)
80D8 03                  INCA
80D9 2A 1F FA            LDA EQUAL   ; Read Equal status
80DC 21 00               TEQA #0x00  ; Expecting E=0 and <7:1> = 0
80DE 2B FF B0            JNE FAIL
80E1 30 FF               LDA #0xFF
80E3 03                  INCA
80E4 2A 1F FA            LDA EQUAL   ; Read Equal status
80E7 21 01               TEQA #0x01  ; Expecting E=1 and <7:1> = 0
80E9 2B FF B0            JNE FAIL
80EC 26                  CLRA
80ED 03                  INCA
80EE 2A 1F FA            LDA EQUAL
80F1 21 00               TEQA #0x00  ; Expecting E=0 and <7:1> = 0
80F3 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.04  LDX #0x****   Load X Register with 16 bits immediate value
                         ; --------------------------------------------------------------------
80F6 30 04      TSTOP04  LDA #0x04
80F8 19                  NOTA
80F9 31 78 00            STA LEDPORT ; Output to LED port
80FC 04 12 34            LDX #0x1234
80FF 2A 1F F3            LDA XH      ; Read Reg X MSB into A
8102 21 12               TEQA #0x12
8104 2B FF B0            JNE FAIL
8107 2A 1F F4            LDA XL      ; Read Reg X LSB into A
810A 21 34               TEQA #0x34
810C 2B FF B0            JNE FAIL
810F 04 AB CD            LDX #0xABCD
8112 2A 1F F3            LDA XH      ; Read Reg X MSB into A
8115 21 AB               TEQA #0xAB
8117 2B FF B0            JNE FAIL
811A 2A 1F F4            LDA XL      ; Read Reg X LSB into A
811D 21 CD               TEQA #0xCD
811F 2B FF B0            JNE FAIL
                         ; Test using symbolic
8122 04 00 0F            LDX #?b0    ; ?b0      EQU 0x000F
8125 2A 1F F3            LDA XH      ; Read Reg X MSB into A
8128 21 00               TEQA #0x00
812A 2B FF B0            JNE FAIL
812D 2A 1F F4            LDA XL      ; Read Reg X LSB into A
8130 21 0F               TEQA #0x0F
8132 2B FF B0            JNE FAIL
8135 04 1F F0            LDX #SP     ; SP       EQU 0x1FF0
8138 2A 1F F3            LDA XH      ; Read Reg X MSB into A
813B 21 1F               TEQA #0x1F
813D 2B FF B0            JNE FAIL
8140 2A 1F F4            LDA XL      ; Read Reg X LSB into A
8143 21 F0               TEQA #0xF0
8145 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.05  INCX   Increment Register X,  Carry Not Updated
                         ; --------------------------------------------------------------------
8148 30 05      TSTOP05  LDA #0x05
814A 19                  NOTA
814B 31 78 00            STA LEDPORT ; Output to LED port
814E 04 00 00            LDX #0x0000 ; Clear X register
8151 05                  INCX        ; Increment X
8152 2A 1F F4            LDA XL      ; Read Reg X LSB into A
8155 21 01               TEQA #0x01
8157 2B FF B0            JNE FAIL
815A 2A 1F F3            LDA XH      ; Read Reg X MSB into A
815D 21 00               TEQA #0x00
815F 2B FF B0            JNE FAIL
8162 05                  INCX
8163 2A 1F F4            LDA XL      ; Read Reg X LSB into A
8166 21 02               TEQA #0x02
8168 2B FF B0            JNE FAIL
816B 2A 1F F3            LDA XH      ; Read Reg X MSB into A
816E 21 00               TEQA #0x00
8170 2B FF B0            JNE FAIL

8173 04 00 FF            LDX #0x00FF ; Test a carry set
8176 05                  INCX        ; Increment X
8177 2A 1F F4            LDA XL      ; Read Reg X LSB into A
817A 21 00               TEQA #0x00
817C 2B FF B0            JNE FAIL
817F 2A 1F F3            LDA XH      ; Read Reg X MSB into A
8182 21 01               TEQA #0x01
8184 2B FF B0            JNE FAIL
8187 05                  INCX        ; Increment X
8188 2A 1F F4            LDA XL      ; Read Reg X LSB into A
818B 21 01               TEQA #0x01
818D 2B FF B0            JNE FAIL
8190 2A 1F F3            LDA XH      ; Read Reg X MSB into A
8193 21 01               TEQA #0x01
8195 2B FF B0            JNE FAIL

8198 04 1E FF            LDX #0x1EFF
819B 05                  INCX        ; Increment X
819C 2A 1F F4            LDA XL      ; Read Reg X LSB into A
819F 21 00               TEQA #0x00
81A1 2B FF B0            JNE FAIL
81A4 2A 1F F3            LDA XH      ; Read Reg X MSB into A
81A7 21 1F               TEQA #0x1F
81A9 2B FF B0            JNE FAIL

81AC 04 FF FF            LDX #0xFFFF
81AF 05                  INCX        ; Increment X
81B0 2A 1F F4            LDA XL      ; Read Reg X LSB into A
81B3 21 00               TEQA #0x00
81B5 2B FF B0            JNE FAIL
81B8 2A 1F F3            LDA XH      ; Read Reg X MSB into A
81BB 21 00               TEQA #0x00
81BD 2B FF B0            JNE FAIL

                         ; --------------------------------------------------------------------
                         ; OP.06 JSR    Jump to SubRoutine
                         ; --------------------------------------------------------------------
81C0 30 06      TSTOP06  LDA #0x06
81C2 19                  NOTA
81C3 31 78 00            STA LEDPORT ; Output to LED port
81C6 06 FF C0            JSR TJSR1   ; 1 layer
81C9 06 FF C3            JSR TJSR2   ; 2
81CC 06 FF C9            JSR TJSR3   ; 3
81CF 06 FF CF            JSR TJSR4   ; 4
81D2 06 FF D5            JSR TJSR5   ; 5
81D5 06 FF DB            JSR TJSR6   ; 6
81D8 06 FF E1            JSR TJSR7   ; 7
81DB 06 FF E7            JSR TJSR8   ; 8
81DE 06 FF ED            JSR TJSR9   ; 9
81E1 06 FF F3            JSR TJSR10  ; 10
                         ; --------------------------------------------------------------------
                         ; OP.07 RTS    ReTurn from Subroutine
                         ; Tested in OP.06 JSR
                         ; --------------------------------------------------------------------
                         ;LDA #07H
                         ;NOTA
                         ;STA LEDPORT ; Output to LED port
                         ; --------------------------------------------------------------------
                         ; OP.08 STOP
                         ; STOP EXECUTING
                         ; Cannot test here it will stop execution...
                         ; A diagnostic test failure is expected to call this instruction ending 
                         ; program exectution.
                         ; --------------------------------------------------------------------
                         ;LDA #08H
                         ;NOTA
                         ;STA LEDPORT ; Output to LED port
                         ;STOP
                         ; --------------------------------------------------------------------
                         ; OP.09 NOP   NO OPERATION
                         ; --------------------------------------------------------------------
81E4 30 09      TSTOP09  LDA #0x09
81E6 19                  NOTA
81E7 31 78 00            STA LEDPORT ; Output to LED port
81EA 09                  NOP
81EB 09                  NOP
81EC 09                  NOP
                         ; --------------------------------------------------------------------
                         ; OP.0A LDA (X) Load Reg A Indexed
                         ; --------------------------------------------------------------------
81ED 30 0A      TSTOP0A  LDA #0x0A
81EF 19                  NOTA
81F0 31 78 00            STA LEDPORT ; Output to LED port
81F3 30 55               LDA #0x55   ; Store some value in RAM
81F5 31 01 00            STA 0x0100
81F8 30 AA               LDA #0xAA
81FA 31 01 01            STA 0x0101
81FD 30 DE               LDA #0xDE
81FF 31 01 F0            STA 0x01F0
8202 30 CA               LDA #0xCA
8204 31 01 FF            STA 0x01FF
8207 04 01 00            LDX #0x0100 ; Verify each locations
820A 0A                  LDA (X)
820B 21 55               TEQA #0x55
820D 2B FF B0            JNE FAIL    ; Jump if result not good
8210 04 01 01            LDX #0x0101
8213 0A                  LDA (X)
8214 21 AA               TEQA #0xAA
8216 2B FF B0            JNE FAIL
8219 04 01 F0            LDX #0x01F0
821C 0A                  LDA (X)
821D 21 DE               TEQA #0xDE
821F 2B FF B0            JNE FAIL
8222 04 01 FF            LDX #0x01FF
8225 0A                  LDA (X)
8226 21 CA               TEQA #0xCA
8228 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.0B STA (X) Store Reg A Indexed
                         ; --------------------------------------------------------------------
822B 30 0B      TSTOP0B  LDA #0x0B
822D 19                  NOTA
822E 31 78 00            STA LEDPORT ; Output to LED port
                         ; --------------------------------------------------------------------
                         ; OP.0C JRA 0x** Unconditional relative jump
                         ; --------------------------------------------------------------------
                         ; Testing using hexadecimal value after the mnemonic
8231 30 0C               LDA #0x0C
8233 19                  NOTA
8234 31 78 00            STA LEDPORT ; Output to LED port
8237 0C 00               JRA 0x00    ; Test jump foward, Execute next instruction
8239 0C 01               JRA 0x01    ; Skip next instruction
823B 09                  NOP         ; 1
823C 0C 02               JRA 0x02    ; Skip next 2 instructions
823E 09                  NOP         ; 1
823F 09                  NOP         ; 2
8240 0C 03               JRA 0x03    ; Skip next 3 instructions
8242 09                  NOP         ; 1 
8243 09                  NOP         ; 2
8244 09                  NOP         ; 3
8245 0C 05               JRA 0x05    ; Skip next 5 instructions
8247 09                  NOP         ; 1
8248 09                  NOP         ; 2
8249 09                  NOP         ; 3
824A 09                  NOP         ; 4
824B 09                  NOP         ; 5
824C 0C 10               JRA 0x10    ; Skip next 16 instructions
