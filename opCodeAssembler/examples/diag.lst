                         ; --------------------------------------------------------------------
                         ; OP.1B LDX s.0x**  
                         ; LDX using a 8-bit direct address (8-bit offset into 0x00–0xFF page)
                         ; --------------------------------------------------------------------
89F9 30 1B      TSTOP1B  LDA #0x1B
89FB 19                  NOTA
89FC 31 78 00            STA LEDPORT    ; Output to LED port
89FF 26                  CLRA
8A00 31 00 00            STA 0x0000
8A03 31 00 01            STA 0x0001
8A06 1B 00               LDX s.0x00     ; Load index pointer from this 8 bit address
8A08 2A 1F F3            LDA 0x1FF3     ; read X MSB
8A0B 2D 00               CMPA #0x00
8A0D 2B FF B0            JNE FAIL
8A10 2A 1F F4            LDA 0x1FF4     ; read X LSB
8A13 2D 00               CMPA #0x00
8A15 2B FF B0            JNE FAIL       ;
8A18 30 AB               LDA #0xAB
8A1A 31 00 02            STA 0x0002
8A1D 30 CD               LDA #0xCD
8A1F 31 00 03            STA 0x0003
8A22 1B 02               LDX s.0x02     ; Load index pointer from this 8 bit address
8A24 2A 1F F3            LDA 0x1FF3     ; read X MSB
8A27 2D AB               CMPA #0xAB
8A29 2B FF B0            JNE FAIL
8A2C 2A 1F F4            LDA 0x1FF4     ; read X LSB
8A2F 2D CD               CMPA #0xCD
8A31 2B FF B0            JNE FAIL       ;      
8A34 30 CA               LDA #0xCA
8A36 31 00 48            STA 0x0048
8A39 30 FE               LDA #0xFE
8A3B 31 00 49            STA 0x0049
8A3E 1B 48               LDX s.0x48     ; Load index pointer from this 8 bit address
8A40 2A 1F F3            LDA 0x1FF3     ; read X MSB
8A43 2D CA               CMPA #0xCA
8A45 2B FF B0            JNE FAIL
8A48 2A 1F F4            LDA 0x1FF4     ; read X LSB
8A4B 2D FE               CMPA #0xFE
8A4D 2B FF B0            JNE FAIL
8A50 30 12               LDA #0x12      ; Test using symbolic adress
8A52 31 00 0E            STA 0x000E     ; ?b1
8A55 30 34               LDA #0x34
8A57 31 00 0F            STA 0x000F     ; ?b0
8A5A 1B 0E               LDX s.?b1      ; Load index pointer using symbolic LSB 8 bit address
8A5C 2A 1F F3            LDA 0x1FF3     ; read X MSB
8A5F 2D 12               CMPA #0x12
8A61 2B FF B0            JNE FAIL
8A64 2A 1F F4            LDA 0x1FF4     ; read X LSB
8A67 2D 34               CMPA #0x34
8A69 2B FF B0            JNE FAIL
8A6C 30 56               LDA #0x56      ; Test using symbolic adress
8A6E 31 00 09            STA 0x0009     ; ?b6
8A71 30 78               LDA #0x78
8A73 31 00 0A            STA 0x000A     ; ?b7
8A76 1B 09               LDX s.?b6      ; Load index pointer using symbolic LSB 8 bit address
8A78 2A 1F F3            LDA 0x1FF3     ; read X MSB
8A7B 2D 56               CMPA #0x56
8A7D 2B FF B0            JNE FAIL
8A80 2A 1F F4            LDA 0x1FF4     ; read X LSB
8A83 2D 78               CMPA #0x78
8A85 2B FF B0            JNE FAIL
                         ; Test symbolic +- offset

                         ; --------------------------------------------------------------------
                         ; OP.1C LDA (****H,X)
                         ; LDA indexed indirect addressing
                         ; --------------------------------------------------------------------
8A88 30 1C      TSTOP1C  LDA #0x1C
8A8A 19                  NOTA
8A8B 31 78 00            STA LEDPORT    ; Output to LED port
                         ;Store a few bytes in RAM to be read using indexed indirect addressing
                         ;test with base address not requiring a carry to MSB
                         ;by incrementing X from 0x0000 upwards
8A8E 30 55               LDA #0x55
8A90 31 00 00            STA 0x0000
8A93 30 AA               LDA #0xAA
8A95 31 00 01            STA 0x0001
8A98 30 BE               LDA #0xBE
8A9A 31 00 02            STA 0x0002
8A9D 04 00 00            LDX #0x0000
8AA0 1C 00 00            LDA (0x0000,X)
8AA3 2D 55               CMPA #0x55
8AA5 2B FF B0            JNE FAIL
8AA8 05                  INCX
8AA9 1C 00 00            LDA (0x0000,X)
8AAC 2D AA               CMPA #0xAA
8AAE 2B FF B0            JNE FAIL
8AB1 05                  INCX
8AB2 1C 00 00            LDA (0x0000,X) 
8AB5 2D BE               CMPA #0xBE
8AB7 2B FF B0            JNE FAIL
                         ; Now test with a base address requiring a carry to MSB
                         ; by initializing X to 0x00FF and incrementing
                         ; storing data at 0x10FE onwards
8ABA 30 12               LDA #0x12
8ABC 31 10 FE            STA 0x10FE
8ABF 30 34               LDA #0x34
8AC1 31 10 FF            STA 0x10FF
8AC4 30 56               LDA #0x56
8AC6 31 11 00            STA 0x1100
8AC9 30 78               LDA #0x78
8ACB 31 11 01            STA 0x1101
8ACE 04 00 00            LDX #0x0000 ; Point to LSB of base address   
8AD1 1C 10 FE            LDA (0x10FE,X)
8AD4 2D 12               CMPA #0x12
8AD6 2B FF B0            JNE FAIL
8AD9 05                  INCX
8ADA 1C 10 FE            LDA (0x10FE,X)
8ADD 2D 34               CMPA #0x34
8ADF 2B FF B0            JNE FAIL
8AE2 05                  INCX
8AE3 1C 10 FE            LDA (0x10FE,X)
8AE6 2D 56               CMPA #0x56
8AE8 2B FF B0            JNE FAIL
8AEB 05                  INCX
8AEC 1C 10 FE            LDA (0x10FE,X)
8AEF 2D 78               CMPA #0x78
8AF1 2B FF B0            JNE FAIL 
                         ; Finally test using a fixed indexed register with variable offset
                         ; storing data at 0x1234 onwards
8AF4 30 12               LDA #0x12
8AF6 31 12 34            STA 0x1234
8AF9 30 34               LDA #0x34
8AFB 31 12 35            STA 0x1235
8AFE 30 56               LDA #0x56
8B00 31 12 36            STA 0x1236
8B03 30 78               LDA #0x78
8B05 31 12 37            STA 0x1237
8B08 04 12 34            LDX #0x1234 ; Point to base address
8B0B 1C 00 00            LDA (0x0000,X)
8B0E 2D 12               CMPA #0x12
8B10 2B FF B0            JNE FAIL
8B13 1C 00 01            LDA (0x0001,X)
8B16 2D 34               CMPA #0x34
8B18 2B FF B0            JNE FAIL
8B1B 1C 00 02            LDA (0x0002,X)
8B1E 2D 56               CMPA #0x56
8B20 2B FF B0            JNE FAIL
8B23 1C 00 03            LDA (0x0003,X)
8B26 2D 78               CMPA #0x78
8B28 2B FF B0            JNE FAIL
                         ; Test using a fixed index register with carry to MSB
8B2B 30 9A               LDA #0x9A
8B2D 31 12 FE            STA 0x12FE
8B30 30 BC               LDA #0xBC   
8B32 31 12 FF            STA 0x12FF
8B35 30 DE               LDA #0xDE
8B37 31 13 00            STA 0x1300
8B3A 30 F0               LDA #0xF0
8B3C 31 13 01            STA 0x1301
8B3F 04 01 FE            LDX #0x01FE ; Point to base address
8B42 1C 11 00            LDA (0x1100,X)
8B45 2D 9A               CMPA #0x9A
8B47 2B FF B0            JNE FAIL
8B4A 1C 11 01            LDA (0x1101,X)
8B4D 2D BC               CMPA #0xBC
8B4F 2B FF B0            JNE FAIL
8B52 1C 11 02            LDA (0x1102,X)
8B55 2D DE               CMPA #0xDE
8B57 2B FF B0            JNE FAIL
8B5A 1C 11 03            LDA (0x1103,X)
8B5D 2D F0               CMPA #0xF0
8B5F 2B FF B0            JNE FAIL
                         ; Test using symbolic with fixed index register to 0
8B62 30 DE               LDA #0xDE
8B64 31 00 00            STA 0x0000
8B67 30 AD               LDA #0xAD
8B69 31 00 01            STA 0x0001
8B6C 30 BE               LDA #0xBE
8B6E 31 00 02            STA 0x0002
8B71 30 EF               LDA #0xEF
8B73 31 00 03            STA 0x0003
8B76 04 00 00            LDX #0x0000 ; Clear index
8B79 1C 00 00            LDA (?b15,X)
8B7C 2D DE               CMPA #0xDE
8B7E 2B FF B0            JNE FAIL
8B81 1C 00 01            LDA (?b14,X)
8B84 2D AD               CMPA #0xAD
8B86 2B FF B0            JNE FAIL
8B89 1C 00 02            LDA (?b13,X)
8B8C 2D BE               CMPA #0xBE
8B8E 2B FF B0            JNE FAIL
8B91 1C 00 03            LDA (?b12,X)
8B94 2D EF               CMPA #0xEF
8B96 2B FF B0            JNE FAIL
                         ; Test using symbolic and incrementing index
8B99 30 CA               LDA #0xCA   ; ?b7      EQU 0x0008
8B9B 31 00 08            STA 0x0008
8B9E 30 FE               LDA #0xFE
8BA0 31 00 09            STA 0x0009
8BA3 30 55               LDA #0x55
8BA5 31 00 0A            STA 0x000A
8BA8 30 AA               LDA #0xAA
8BAA 31 00 0B            STA 0x000B
8BAD 04 00 00            LDX #0x0000 ; Clear index
8BB0 1C 00 08            LDA (?b7,X)
8BB3 2D CA               CMPA #0xCA
8BB5 2B FF B0            JNE FAIL
8BB8 05                  INCX
8BB9 1C 00 08            LDA (?b7,X)
8BBC 2D FE               CMPA #0xFE
8BBE 2B FF B0            JNE FAIL
8BC1 05                  INCX
8BC2 1C 00 08            LDA (?b7,X)
8BC5 2D 55               CMPA #0x55
8BC7 2B FF B0            JNE FAIL
8BCA 05                  INCX
8BCB 1C 00 08            LDA (?b7,X)
8BCE 2D AA               CMPA #0xAA
8BD0 2B FF B0            JNE FAIL              
                         ; Test using symbolic and incrementing index with a carry
8BD3 30 12               LDA #0x12   ; ?b0      EQU 0x000F
8BD5 31 16 FE            STA 0x16FE
8BD8 30 34               LDA #0x34
8BDA 31 16 FF            STA 0x16FF
8BDD 30 56               LDA #0x56
8BDF 31 17 00            STA 0x1700
8BE2 30 78               LDA #0x78
8BE4 31 17 01            STA 0x1701
8BE7 04 16 EF            LDX #0x16EF ; Set base index
8BEA 1C 00 0F            LDA (?b0,X)
8BED 2D 12               CMPA #0x12
8BEF 2B FF B0            JNE FAIL              
8BF2 05                  INCX
8BF3 1C 00 0F            LDA (?b0,X)
8BF6 2D 34               CMPA #0x34
8BF8 2B FF B0            JNE FAIL              
8BFB 05                  INCX        ; carry on MSB
8BFC 1C 00 0F            LDA (?b0,X)
8BFF 2D 56               CMPA #0x56
8C01 2B FF B0            JNE FAIL              
8C04 05                  INCX
8C05 1C 00 0F            LDA (?b0,X)
8C08 2D 78               CMPA #0x78
8C0A 2B FF B0            JNE FAIL              
                         ; --------------------------------------------------------------------
                         ; OP.1D STA (****H,X)
                         ; STA indexed indirect addressing
                         ; --------------------------------------------------------------------
8C0D 30 1D      TSTOP1D  LDA #0x1D
8C0F 19                  NOTA
8C10 31 78 00            STA LEDPORT    ; Output to LED port
                         ;Store a few bytes in RAM using indexed indirect addressing
                         ;test with base address not requiring a carry to MSB
                         ;by incrementing X from 0x0000 upwards
8C13 30 55               LDA #0x55      ; store data at 0x0000 onwards
8C15 04 00 00            LDX #0x0000
8C18 1D 00 00            STA (0x0000,X)
8C1B 30 AA               LDA #0xAA
8C1D 05                  INCX
8C1E 1D 00 00            STA (0x0000,X)
8C21 30 BE               LDA #0xBE
8C23 05                  INCX
8C24 1D 00 00            STA (0x0000,X)
8C27 04 00 00            LDX #0x0000    ; Now read back the stored data
8C2A 0A                  LDA (X)
8C2B 2D 55               CMPA #0x55
8C2D 2B FF B0            JNE FAIL
8C30 05                  INCX
8C31 0A                  LDA (X)
8C32 2D AA               CMPA #0xAA
8C34 2B FF B0            JNE FAIL 
8C37 05                  INCX
8C38 0A                  LDA (X) 
8C39 2D BE               CMPA #0xBE
8C3B 2B FF B0            JNE FAIL
                         ; Now test with a base address requiring a carry to MSB
                         ; by initializing X to 0x10FE and incrementing storing data
8C3E 30 12               LDA #0x12
8C40 04 10 FE            LDX #0x10FE
8C43 1D 00 00            STA (0x0000,X)
8C46 30 34               LDA #0x34
8C48 05                  INCX
8C49 1D 00 00            STA (0x0000,X)
8C4C 30 56               LDA #0x56
8C4E 05                  INCX
8C4F 1D 00 00            STA (0x0000,X)
8C52 30 78               LDA #0x78
8C54 05                  INCX
8C55 1D 00 00            STA (0x0000,X)
8C58 04 10 FE            LDX #0x10FE ; Initialize X to base address
8C5B 0A                  LDA (X)
8C5C 2D 12               CMPA #0x12
8C5E 2B FF B0            JNE FAIL
8C61 05                  INCX
8C62 0A                  LDA (X)
8C63 2D 34               CMPA #0x34
8C65 2B FF B0            JNE FAIL
8C68 05                  INCX
8C69 0A                  LDA (X)
8C6A 2D 56               CMPA #0x56
8C6C 2B FF B0            JNE FAIL
8C6F 05                  INCX
8C70 0A                  LDA (X)
8C71 2D 78               CMPA #0x78
8C73 2B FF B0            JNE FAIL
                         ; Test using a fixed indexed register with variable offset
                         ; storing data at 0x1234 onwards
8C76 30 12               LDA #0x12
8C78 04 12 34            LDX #0x1234
8C7B 1D 00 00            STA (0x0000,X)
8C7E 30 34               LDA #0x34
8C80 1D 00 01            STA (0x0001,X)
8C83 30 56               LDA #0x56
8C85 1D 00 02            STA (0x0002,X)
8C88 30 78               LDA #0x78
8C8A 1D 00 03            STA (0x0003,X)
8C8D 04 12 34            LDX #0x1234 ; Point to base address
8C90 0A                  LDA (X)
8C91 2D 12               CMPA #0x12
8C93 2B FF B0            JNE FAIL
8C96 1C 00 01            LDA (0x0001,X)
8C99 2D 34               CMPA #0x34
8C9B 2B FF B0            JNE FAIL
8C9E 1C 00 02            LDA (0x0002,X)
8CA1 2D 56               CMPA #0x56
8CA3 2B FF B0            JNE FAIL
8CA6 1C 00 03            LDA (0x0003,X)
8CA9 2D 78               CMPA #0x78
8CAB 2B FF B0            JNE FAIL
                         ; Test using a fixed index register with carry to MSB
8CAE 30 9A               LDA #0x9A
8CB0 04 14 FE            LDX #0x14FE
8CB3 1D 00 00            STA (0x0000,X)
8CB6 30 BC               LDA #0xBC
8CB8 1D 00 01            STA (0x0001,X)
8CBB 30 DE               LDA #0xDE
8CBD 1D 00 02            STA (0x0002,X)
8CC0 30 F0               LDA #0xF0
8CC2 1D 00 03            STA (0x0003,X)
8CC5 04 14 FE            LDX #0x14FE ; Point to base address
8CC8 0A                  LDA (X)
8CC9 2D 9A               CMPA #0x9A
8CCB 2B FF B0            JNE FAIL
8CCE 05                  INCX
8CCF 0A                  LDA (X)
8CD0 2D BC               CMPA #0xBC
8CD2 2B FF B0            JNE FAIL
8CD5 05                  INCX
8CD6 0A                  LDA (X)
8CD7 2D DE               CMPA #0xDE
8CD9 2B FF B0            JNE FAIL
8CDC 05                  INCX
8CDD 0A                  LDA (X)
8CDE 2D F0               CMPA #0xF0
8CE0 2B FF B0            JNE FAIL
                         ; Test with carry to MSB on index and base address
8CE3 30 45               LDA #0x45
8CE5 04 02 FE            LDX #0x02FE
8CE8 1D 11 00            STA (0x1100,X)
8CEB 30 67               LDA #0x67
8CED 1D 11 01            STA (0x1101,X)
8CF0 30 89               LDA #0x89
8CF2 1D 11 02            STA (0x1102,X)
8CF5 30 AB               LDA #0xAB
8CF7 1D 11 03            STA (0x1103,X)
8CFA 04 01 FE            LDX #0x01FE ; Point to base address
8CFD 1C 12 00            LDA (0x1200,X)
8D00 2D 45               CMPA #0x45
8D02 2B FF B0            JNE FAIL
8D05 05                  INCX
8D06 1C 12 00            LDA (0x1200,X)
8D09 2D 67               CMPA #0x67
8D0B 2B FF B0            JNE FAIL
8D0E 05                  INCX
8D0F 1C 12 00            LDA (0x1200,X)
8D12 2D 89               CMPA #0x89
8D14 2B FF B0            JNE FAIL
8D17 05                  INCX
8D18 1C 12 00            LDA (0x1200,X)
8D1B 2D AB               CMPA #0xAB
8D1D 2B FF B0            JNE FAIL
                         ; test using symbolic with fixed index register to 0
8D20 04 00 00            LDX #0x0000 ; Clear index
8D23 30 DE               LDA #0xDE
8D25 1D 00 05            STA (?b10,X)
8D28 30 AD               LDA #0xAD
8D2A 1D 00 06            STA (?b9,X)
8D2D 30 BE               LDA #0xBE
8D2F 1D 00 07            STA (?b8,X)   
8D32 30 EF               LDA #0xEF
8D34 1D 00 08            STA (?b7,X)
8D37 2A 00 05            LDA 0x0005
8D3A 2D DE               CMPA #0xDE
8D3C 2B FF B0            JNE FAIL
8D3F 2A 00 06            LDA 0x0006
8D42 2D AD               CMPA #0xAD
8D44 2B FF B0            JNE FAIL
8D47 2A 00 07            LDA 0x0007
8D4A 2D BE               CMPA #0xBE
8D4C 2B FF B0            JNE FAIL
8D4F 2A 00 08            LDA 0x0008
8D52 2D EF               CMPA #0xEF
8D54 2B FF B0            JNE FAIL
                         ; test using symbolic and incrementing index
8D57 04 00 00            LDX #0x0000 ; Clear index
8D5A 30 CA               LDA #0xCA   
8D5C 1D 00 0F            STA (?b0,X) ; ?b0      EQU 0x000F
8D5F 05                  INCX
8D60 30 FE               LDA #0xFE
8D62 1D 00 0F            STA (?b0,X)
8D65 05                  INCX 
8D66 30 55               LDA #0x55
8D68 1D 00 0F            STA (?b0,X)
8D6B 05                  INCX
8D6C 30 AA               LDA #0xAA
8D6E 1D 00 0F            STA (?b0,X)
8D71 2A 00 0F            LDA 0x000F
8D74 2D CA               CMPA #0xCA
8D76 2B FF B0            JNE FAIL
8D79 2A 00 10            LDA 0x0010
8D7C 2D FE               CMPA #0xFE
8D7E 2B FF B0            JNE FAIL
8D81 2A 00 11            LDA 0x0011
8D84 2D 55               CMPA #0x55
8D86 2B FF B0            JNE FAIL
8D89 2A 00 12            LDA 0x0012
8D8C 2D AA               CMPA #0xAA
8D8E 2B FF B0            JNE FAIL         
                         ; Test using symbolic and incrementing index with a carry
8D91 04 14 EF            LDX #0x14EF ; Set base index
8D94 30 12               LDA #0x12
8D96 1D 00 0F            STA (?b0,X) ; 0x14FE
8D99 05                  INCX
8D9A 30 34               LDA #0x34
8D9C 1D 00 0F            STA (?b0,X) ; 0x14FF
8D9F 05                  INCX
8DA0 30 56               LDA #0x56
8DA2 1D 00 0F            STA (?b0,X) ; 0x1500
8DA5 05                  INCX
8DA6 30 78               LDA #0x78
8DA8 1D 00 0F            STA (?b0,X) ; 0x1501
8DAB 2A 14 FE            LDA 0x14FE
8DAE 2D 12               CMPA #0x12
8DB0 2B FF B0            JNE FAIL
8DB3 2A 14 FF            LDA 0x14FF
8DB6 2D 34               CMPA #0x34
8DB8 2B FF B0            JNE FAIL
8DBB 2A 15 00            LDA 0x1500
8DBE 2D 56               CMPA #0x56
8DC0 2B FF B0            JNE FAIL
8DC3 2A 15 01            LDA 0x1501
8DC6 2D 78               CMPA #0x78
8DC8 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.1E CLRX
                         ; CLEAR X REGISTER
                         ; --------------------------------------------------------------------
8DCB 30 1E      TSTOP1E  LDA #0x1E
8DCD 19                  NOTA
8DCE 31 78 00            STA LEDPORT ; Output to LED port
8DD1 26                  CLRA        ; Clear E equal flag
8DD2 31 1F FA            STA 0x1FFA
8DD5 04 FF FF            LDX #0xFFFF ; Load X with non zero value
8DD8 1E                  CLRX
8DD9 2A 1F F3            LDA 0x1FF3  ; Read X MSB
8DDC 2D 00               CMPA #0x00
8DDE 2B FF B0            JNE FAIL
8DE1 2A 1F F4            LDA 0x1FF4  ; Read X LSB
8DE4 2D 00               CMPA #0x00
8DE6 2B FF B0            JNE FAIL
8DE9 2A 1F FA            LDA 0x1FFA  ; Read E flag and check it is set
8DEC 2D 01               CMPA #0x01
8DEE 2B FF B0            JNE FAIL
8DF1 30 01               LDA #0x01   ; Set E equal flag
8DF3 31 1F FA            STA 0x1FFA
8DF6 04 12 34            LDX #0x1234 ; Load X with non zero value
8DF9 1E                  CLRX
8DFA 2A 1F F3            LDA 0x1FF3  ; Read X MSB
8DFD 2D 00               CMPA #0x00
8DFF 2B FF B0            JNE FAIL
8E02 2A 1F F4            LDA 0x1FF4  ; Read X LSB
8E05 2D 00               CMPA #0x00
8E07 2B FF B0            JNE FAIL
8E0A 2A 1F FA            LDA 0x1FFA  ; Read E flag and check it is set
8E0D 2D 01               CMPA #0x01  
8E0F 2B FF B0            JNE FAIL
                         ; -----------------------------------------------------
                         ; OP.1F CMPA 0x**** 
                         ; Compare A with direct-addressed byte
                         ; A - Direct Addressing, A unchanged, E and C updated
                         ; -----------------------------------------------------
8E12 30 1F      TSTOP1F  LDA #0x1F
8E14 19                  NOTA
8E15 31 78 00            STA LEDPORT ; Output to LED port
8E18 30 5A               LDA #0x5A   ; Store a value in RAM
8E1A 31 02 00            STA 0x0200   
8E1D 30 5A               LDA #0x5A   ; -- Compare with same value --
8E1F 1F 02 00            CMPA 0x0200 
8E22 2B FF B0            JNE FAIL    ; Jump if result say not equal
8E25 2A 1F FA            LDA EQUAL   ; Read E flag and check it is set
8E28 21 01               TEQA #0x01
8E2A 2B FF B0            JNE FAIL
8E2D 2A 1F FB            LDA CARRY   ; Read Carry flag and check it is set
8E30 21 01               TEQA #0x01
8E32 2B FF B0            JNE FAIL
8E35 30 3C               LDA #0x3C   ; -- Compare with A < Memory --
8E37 1F 02 00            CMPA 0x0200 
8E3A 2C FF B0            JEQ FAIL    ; Jump if result indicates equality
8E3D 2A 1F FA            LDA EQUAL   ; Read E flag and check it is cleared
8E40 21 00               TEQA #0x00
8E42 2B FF B0            JNE FAIL
8E45 2A 1F FB            LDA CARRY   ; Read Carry flag and check it is cleared
8E48 21 00               TEQA #0x00
8E4A 2B FF B0            JNE FAIL
8E4D 30 7E               LDA #0x7E   ; -- Compare with A > Memory --
8E4F 1F 02 00            CMPA 0x0200 
8E52 2C FF B0            JEQ FAIL    ; Jump if result indicates equality
8E55 2A 1F FA            LDA EQUAL   ; Read E flag and check it is cleared
8E58 2D 00               CMPA #0x00  
8E5A 2B FF B0            JNE FAIL
8E5D 2A 1F FB            LDA CARRY   ; Read Carry flag and check it is set
8E60 21 01               TEQA #0x01
8E62 2B FF B0            JNE FAIL
                         ; Test all bits for CMPA operation
8E65 26                  CLRA
8E66 31 15 67            STA 0x1567
8E69 30 FF               LDA #0xFF
8E6B 31 17 89            STA 0x1789
8E6E 26                  CLRA
8E6F 1F 15 67            CMPA 0x1567
8E72 2B FF B0            JNE FAIL
8E75 2A 1F FA            LDA EQUAL
8E78 21 01               TEQA #0x01
8E7A 2B FF B0            JNE FAIL
8E7D 30 FF               LDA #0xFF
8E7F 1F 17 89            CMPA 0x1789
8E82 2B FF B0            JNE FAIL
8E85 2A 1F FA            LDA EQUAL
8E88 21 01               TEQA #0x01
8E8A 2B FF B0            JNE FAIL 
8E8D 30 AA               LDA #0xAA
8E8F 1F 15 67            CMPA 0x1567
8E92 2C FF B0            JEQ FAIL
8E95 2A 1F FA            LDA EQUAL
8E98 21 00               TEQA #0x00
8E9A 2B FF B0            JNE FAIL
8E9D 30 55               LDA #0x55
8E9F 1F 17 89            CMPA 0x1789
8EA2 2C FF B0            JEQ FAIL
8EA5 2A 1F FA            LDA EQUAL
8EA8 21 00               TEQA #0x00
8EAA 2B FF B0            JNE FAIL
                         ; Test with symbolic address
8EAD 30 41               LDA #0x41      ; 'A'
8EAF 1F 9E 29            CMPA MSGTXT1   ; '1' 
8EB2 2C FF B0            JEQ FAIL
8EB5 30 31               LDA #0x31      ; '1'
8EB7 1F 9E 29            CMPA MSGTXT1   ; '1'
8EBA 2B FF B0            JNE FAIL
8EBD 30 57               LDA #0x57      ; 'W'
8EBF 1F 9E 36            CMPA MSGTXT2+6 ; 'W'
8EC2 2B FF B0            JNE FAIL
8EC5 30 54               LDA #0x54
8EC7 1F 9E 3C            CMPA MSGTXT3   ; 'T'
8ECA 2B FF B0            JNE FAIL
8ECD 30 68               LDA #0x68
8ECF 1F 9E 3D            CMPA MSGTXT3+1 ; 'h'
8ED2 2B FF B0            JNE FAIL
8ED5 30 69               LDA #0x69
8ED7 1F 9E 3E            CMPA MSGTXT3+2 ; 'i'
8EDA 2B FF B0            JNE FAIL
8EDD 30 73               LDA #0x73
8EDF 1F 9E 3F            CMPA MSGTXT3+3 ; 's'
8EE2 2B FF B0            JNE FAIL
8EE5 30 20               LDA #0x20
8EE7 1F 9E 40            CMPA MSGTXT3+4 ; ' '
8EEA 2B FF B0            JNE FAIL
8EED 30 69               LDA #0x69
8EEF 1F 9E 41            CMPA MSGTXT3+5 ; 'i'
8EF2 2B FF B0            JNE FAIL
8EF5 30 73               LDA #0x73
8EF7 1F 9E 42            CMPA MSGTXT3+6 ; 's'
8EFA 2B FF B0            JNE FAIL
8EFD 30 72               LDA #0x72      ; 'r'
8EFF 1F 9E 77            CMPA MSGTXT3+59
8F02 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.20 DECA  
                         ; DECREMENT REGISTER A
                         ; --------------------------------------------------------------------
8F05 30 20      TSTOP20  LDA #0x20
8F07 19                  NOTA
8F08 31 78 00            STA LEDPORT ; Output to LED port
8F0B 30 01               LDA #0x01
8F0D 20                  DECA
8F0E 2D 00               CMPA #0x00
8F10 2B FF B0            JNE FAIL
8F13 20                  DECA
8F14 2D FF               CMPA #0xFF
8F16 2B FF B0            JNE FAIL
8F19 20                  DECA
8F1A 2D FE               CMPA #0xFE
8F1C 2B FF B0            JNE FAIL
8F1F 30 80               LDA #0x80
8F21 20                  DECA
8F22 2D 7F               CMPA #0x7F
8F24 2B FF B0            JNE FAIL
                         ; Test E flag
8F27 26                  CLRA        ; Clear E equal flag
8F28 31 1F FA            STA 0x1FFA 
8F2B 30 01               LDA #0x01
8F2D 20                  DECA
8F2E 2A 1F FA            LDA 0x1FFA
8F31 2D 01               CMPA #0x01 ; Check E flag is set
8F33 2B FF B0            JNE FAIL
8F36 26                  CLRA
8F37 20                  DECA
8F38 2A 1F FA            LDA 0x1FFA
8F3B 2D 00               CMPA #0x00 ; Check E flag is cleared
8F3D 2B FF B0            JNE FAIL
                         ; Check all bits for the E flag
8F40 30 81               LDA #0x81
8F42 20                  DECA
8F43 2A 1F FA            LDA 0x1FFA
8F46 2D 00               CMPA #0x00 ; Check E flag is cleared
8F48 2B FF B0            JNE FAIL
8F4B 30 41               LDA #0x41
8F4D 20                  DECA
8F4E 2A 1F FA            LDA 0x1FFA
8F51 2D 00               CMPA #0x00 ; Check E flag is cleared
8F53 2B FF B0            JNE FAIL
8F56 30 21               LDA #0x21
8F58 20                  DECA
8F59 2A 1F FA            LDA 0x1FFA
8F5C 2D 00               CMPA #0x00 ; Check E flag is cleared
8F5E 2B FF B0            JNE FAIL
8F61 30 11               LDA #0x11
8F63 20                  DECA
8F64 2A 1F FA            LDA 0x1FFA
8F67 2D 00               CMPA #0x00 ; Check E flag is cleared
8F69 2B FF B0            JNE FAIL
8F6C 30 09               LDA #0x09
8F6E 20                  DECA
8F6F 2A 1F FA            LDA 0x1FFA
8F72 2D 00               CMPA #0x00 ; Check E flag is cleared
8F74 2B FF B0            JNE FAIL
8F77 30 05               LDA #0x05
8F79 20                  DECA
8F7A 2A 1F FA            LDA 0x1FFA
8F7D 2D 00               CMPA #0x00 ; Check E flag is cleared
8F7F 2B FF B0            JNE FAIL
8F82 30 03               LDA #0x03
8F84 20                  DECA
8F85 2A 1F FA            LDA 0x1FFA
8F88 2D 00               CMPA #0x00 ; Check E flag is cleared
8F8A 2B FF B0            JNE FAIL
8F8D 30 02               LDA #0x02
8F8F 20                  DECA
8F90 2A 1F FA            LDA 0x1FFA
8F93 2D 00               CMPA #0x00 ; Check E flag is cleared
8F95 2B FF B0            JNE FAIL
                         ; Test all bits for DECA operation
8F98 30 FF               LDA #0xFF
8F9A 20                  DECA
8F9B 2D FE               CMPA #0xFE
8F9D 2B FF B0            JNE FAIL
8FA0 30 7F               LDA #0x7F
8FA2 20                  DECA
8FA3 2D 7E               CMPA #0x7E
8FA5 2B FF B0            JNE FAIL
8FA8 30 3F               LDA #0x3F
8FAA 20                  DECA
8FAB 2D 3E               CMPA #0x3E
8FAD 2B FF B0            JNE FAIL
8FB0 30 1F               LDA #0x1F
8FB2 20                  DECA
8FB3 2D 1E               CMPA #0x1E
8FB5 2B FF B0            JNE FAIL
8FB8 30 0F               LDA #0x0F
8FBA 20                  DECA
8FBB 2D 0E               CMPA #0x0E
8FBD 2B FF B0            JNE FAIL
8FC0 30 07               LDA #0x07
8FC2 20                  DECA
8FC3 2D 06               CMPA #0x06
8FC5 2B FF B0            JNE FAIL
8FC8 30 03               LDA #0x03
8FCA 20                  DECA
8FCB 2D 02               CMPA #0x02
8FCD 2B FF B0            JNE FAIL
8FD0 30 01               LDA #0x01
8FD2 20                  DECA
8FD3 2D 00               CMPA #0x00
8FD5 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.21 TEQA #0x**  
                         ; TEST EQUAL A with imm, A preserved, E updated, C preserved
                         ; --------------------------------------------------------------------
8FD8 30 21      TSTOP21  LDA #0x21
8FDA 19                  NOTA
8FDB 31 78 00            STA LEDPORT ; Output to LED port
8FDE 26                  CLRA        ; Clear Carry flag first
8FDF 31 1F FB            STA CARRY
8FE2 30 5A               LDA #0x5A
8FE4 21 5A               TEQA #0x5A
8FE6 2B FF B0            JNE FAIL
8FE9 2A 1F FA            LDA EQUAL
8FEC 21 01               TEQA #0x01
8FEE 2B FF B0            JNE FAIL
8FF1 2A 1F FB            LDA CARRY   ; Test Carry flag still cleared
8FF4 21 00               TEQA #0x00
8FF6 2B FF B0            JNE FAIL
                         ; Now do the same using a set carry flag
8FF9 30 01               LDA #0x01
8FFB 31 1F FB            STA CARRY
8FFE 30 BD               LDA #0xBD
9000 21 BD               TEQA #0xBD
9002 2B FF B0            JNE FAIL
9005 2A 1F FA            LDA EQUAL
9008 21 01               TEQA #0x01
900A 2B FF B0            JNE FAIL
900D 2A 1F FB            LDA CARRY   ; Test Carry flag still set
9010 21 01               TEQA #0x01
9012 2B FF B0            JNE FAIL
                         ; Now test for not equal
9015 26                  CLRA        ; Clear Carry flag first
9016 31 1F FB            STA CARRY
9019 30 3C               LDA #0x3C
901B 21 4D               TEQA #0x4D
901D 2C FF B0            JEQ FAIL
9020 2A 1F FA            LDA EQUAL
9023 21 00               TEQA #0x00
9025 2B FF B0            JNE FAIL
9028 2A 1F FB            LDA CARRY   ; Test Carry flag still cleared
902B 21 00               TEQA #0x00
902D 2B FF B0            JNE FAIL
                         ; Now do the same using a set carry flag
9030 30 01               LDA #0x01
9032 31 1F FB            STA CARRY
9035 30 7E               LDA #0x7E      
9037 21 6F               TEQA #0x6F
9039 2C FF B0            JEQ FAIL
903C 2A 1F FA            LDA EQUAL
903F 21 00               TEQA #0x00
9041 2B FF B0            JNE FAIL
9044 2A 1F FB            LDA CARRY   ; Test Carry flag still set
9047 21 01               TEQA #0x01
9049 2B FF B0            JNE FAIL
                         ; Test all bits for TEQA operation
904C 30 FF               LDA #0xFF
904E 21 FF               TEQA #0xFF
9050 2B FF B0            JNE FAIL
9053 2A 1F FA            LDA EQUAL
9056 21 01               TEQA #0x01
9058 2B FF B0            JNE FAIL
905B 26                  CLRA
905C 21 00               TEQA #0x00
905E 2B FF B0            JNE FAIL
9061 2A 1F FA            LDA EQUAL
9064 21 01               TEQA #0x01
9066 2B FF B0            JNE FAIL
9069 30 AA               LDA #0xAA
906B 21 AA               TEQA #0xAA
906D 2B FF B0            JNE FAIL
9070 2A 1F FA            LDA EQUAL
9073 21 01               TEQA #0x01
9075 2B FF B0            JNE FAIL
9078 30 55               LDA #0x55
907A 21 55               TEQA #0x55
907C 2B FF B0            JNE FAIL
907F 2A 1F FA            LDA EQUAL
9082 21 01               TEQA #0x01
9084 2B FF B0            JNE FAIL
                         ; --------------------------------------------------------------------
                         ; OP.22 TEQA 0x****  
                         ; TEST EQUAL A with MEM, A preserved, E updated, C preserved
                         ; --------------------------------------------------------------------
9087 30 22      TSTOP22  LDA #0x22
9089 19                  NOTA
908A 31 78 00            STA LEDPORT ; Output to LED port
908D 26                  CLRA        ; Clear Carry flag first
908E 31 1F FB            STA CARRY
9091 30 5A               LDA #0x5A   ; Store a value in RAM
9093 31 02 00            STA 0x0200   
9096 30 5A               LDA #0x5A   ; -- Compare with same value --
9098 22 02 00            TEQA 0x0200
909B 2B FF B0            JNE FAIL    ; Jump if result say not equal
909E 2A 1F FA            LDA EQUAL   ; Read E flag and check it is set
90A1 21 01               TEQA #0x01
90A3 2B FF B0            JNE FAIL
90A6 2A 1F FB            LDA CARRY   ; Read Carry flag and check it is still cleared
90A9 21 00               TEQA #0x00
90AB 2B FF B0            JNE FAIL
                         ; Now do the same using a set carry flag
90AE 30 01               LDA #0x01   ; set Carry flag
90B0 31 1F FB            STA CARRY
90B3 30 BD               LDA #0xBD
90B5 31 05 00            STA 0x0500
